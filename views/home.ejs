<!-- Should show: completed exercises, next lesson, progress summary, lessons learned -->
<h1>Welcome to your Dashboard, <%= username %>!</h1>
<p>Here you can see your progress, access your lessons, and continue your coding journey.</p>

<div id="react-home-widget"></div>
<div id="root"></div>
<script type="module" src="/build/main.js"></script>

<!-- <script type="module" src="/javascripts/reactHomeWidget.js"></script> -->

<div class="dashboard">
    <div class="progress-summary">
        <h2>Progress Summary</h2>
        <p>Completed Exercises: 5</p>
        <p>Next Lesson: Lesson about stuff</p>
    </div>

    <div class="recent-activity">
        <h2>Recent Activity</h2>
        <% if (0 > 0) { %>
            <ul>
                <!-- <% recentActivity.forEach(activity => { %>
                    <li><%= activity %></li>
                <% }) %> -->
            </ul>
        <% } else { %>
            <p>No recent activity. Start coding to see your progress here!</p>
        <% } %>
    </div>
</div>