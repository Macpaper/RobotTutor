<h1>Create New Account</h1>

<% if (error) { %>
  <p style="color: red;"><%= error %></p>
<% } %>

<div id="react-home-widget"></div>
<script type="module" src="/javascripts/reactHomeWidget.js"></script>

<div class="login-container">
    <form method="POST" action="/signup" class="login-form">
    <label>Username</label>
    <input type="text" name="username" class="username-textbox"/>

    <label>Password</label>
    <input type="password" name="password" class="password-textbox"/>

    <button type="submit" class="login-button">Create Account</button>
    </form>
</div>

<p>Already have an account? <a href="/login">Log in here</a></p>
